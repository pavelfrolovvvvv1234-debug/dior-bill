{
  "name": "@dior/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "push": "dotenv -e ../../.env -- prisma db push",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "sql:last-online": "dotenv -e ../../.env -- prisma db execute --schema prisma/schema.prisma --file ../../deploy/sql/add_last_online_at.sql",
    "build": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "bcryptjs": "^3.0.2",
    "@types/bcryptjs": "^2.4.6"
  }
}
