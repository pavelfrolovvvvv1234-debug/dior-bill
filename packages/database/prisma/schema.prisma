generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ─────────────────────────────────────────────

enum UserRole {
  USER
  AFFILIATE_VIP
  SUPPORT
  OPERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  BANNED
}

model User {
  id                String     @id @default(cuid())
  email             String?    @unique
  emailVerified     DateTime?  @map("email_verified")
  passwordHash      String?    @map("password_hash")
  telegramId        BigInt?    @unique @map("telegram_id")
  telegramUsername  String?    @map("telegram_username")
  displayName       String?    @map("display_name")
  avatarUrl         String?    @map("avatar_url")
  role              UserRole   @default(USER)
  status            UserStatus @default(ACTIVE)
  twoFactorEnabled  Boolean    @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?    @map("two_factor_secret")
  referralCode      String     @unique @map("referral_code")
  referredById      String?    @map("referred_by_id")
  referredBy        User?      @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]     @relation("Referrals")
  balance           Decimal    @default(0) @db.Decimal(12, 2)
  balanceLocked     Decimal    @default(0) @map("balance_locked") @db.Decimal(12, 2)
  credits           Decimal    @default(0) @db.Decimal(12, 2)
  locale            String     @default("en")
  timezone          String     @default("UTC")
  theme             String     @default("dark")
  lastLoginAt       DateTime?  @map("last_login_at")
  lastLoginIp       String?    @map("last_login_ip")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  sessions              Session[]
  loginHistory          LoginHistory[]
  deviceSessions        DeviceSession[]
  auditLogs             AuditLog[]            @relation("AuditActor")
  services              Service[]
  invoices              Invoice[]
  transactions          Transaction[]
  payments              Payment[]
  topUps                TopUp[]
  topUpsReviewed        TopUp[]               @relation("TopUpReviewer")
  notifications         Notification[]
  notificationPrefs     NotificationPreference?
  tickets               Ticket[]
  ticketMessages        TicketMessage[]
  referralEarnings      ReferralEarning[]     @relation("Earner")
  referralEarningsFrom  ReferralEarning[]     @relation("Source")
  payoutRequests        PayoutRequest[]
  affiliateTier         AffiliateTier?        @relation(fields: [affiliateTierId], references: [id])
  affiliateTierId       String?               @map("affiliate_tier_id")
  customReferralPercent Decimal?              @map("custom_referral_percent") @db.Decimal(5, 2)
  riskProfile           UserRiskProfile?
  manualReviews         ManualReviewQueue[]
  apiKeys               ApiKey[]
  telegramLinkTokens    TelegramLinkToken[]
  twoFactorRecoveryCodes TwoFactorRecoveryCode[]

  @@index([email])
  @@index([telegramId])
  @@index([referralCode])
  @@index([referredById])
  @@index([status])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique @map("token_hash")
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent") @db.Text
  deviceLabel  String?  @map("device_label")
  isRevoked    Boolean  @default(false) @map("is_revoked")
  createdAt    DateTime @default(now()) @map("created_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String   @map("ip_address")
  userAgent String?  @map("user_agent") @db.Text
  country   String?
  city      String?
  success   Boolean  @default(true)
  method    String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("login_history")
}

model DeviceSession {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String   @map("device_id")
  deviceName String?  @map("device_name")
  platform   String?
  ipAddress  String?  @map("ip_address")
  trusted    Boolean  @default(false)
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("device_sessions")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Infrastructure ─────────────────────────────────────────

model Location {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  country     String
  city        String
  flag        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  nodes              Node[]
  vpsInstances       VpsInstance[]
  dedicatedServers   DedicatedServer[]
  cdnEdgeRegions     CdnEdgeRegion[]

  @@map("locations")
}

model Node {
  id           String   @id @default(cuid())
  name         String
  hostname     String   @unique
  locationId   String   @map("location_id")
  location     Location @relation(fields: [locationId], references: [id])
  type         String
  status       String   @default("online")
  cpuCores     Int      @map("cpu_cores")
  ramGb        Int      @map("ram_gb")
  diskGb       Int      @map("disk_gb")
  loadPercent  Float    @default(0) @map("load_percent")
  activeVps    Int      @default(0) @map("active_vps")
  proxmoxNode      String?  @map("proxmox_node")
  ipv4Available    Int      @default(0) @map("ipv4_available")
  ipv4Total        Int      @default(0) @map("ipv4_total")
  capacityPercent  Float    @default(0) @map("capacity_percent")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  vpsInstances VpsInstance[]
  ipAddresses  IpAddress[]

  @@index([locationId])
  @@index([status])
  @@map("nodes")
}

model IpAddress {
  id         String   @id @default(cuid())
  address    String   @unique
  nodeId     String?  @map("node_id")
  node       Node?    @relation(fields: [nodeId], references: [id])
  locationId String   @map("location_id")
  status     String   @default("available")
  vpsId      String?  @map("vps_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([status, locationId])
  @@index([nodeId])
  @@map("ip_addresses")
}

model VpsSnapshot {
  id          String      @id @default(cuid())
  vpsId       String      @map("vps_id")
  vps         VpsInstance @relation(fields: [vpsId], references: [id], onDelete: Cascade)
  name        String
  proxmoxSnap String?  @map("proxmox_snap")
  sizeGb      Float?   @map("size_gb")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([vpsId])
  @@map("vps_snapshots")
}

model InfrastructureFeed {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String   @db.Text
  severity    String   @default("info")
  locationId  String?  @map("location_id")
  metadata    Json?
  published   Boolean  @default(true)
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([published, createdAt])
  @@map("infrastructure_feed")
}

// ─── Services ───────────────────────────────────────────────

enum ServiceType {
  VPS
  DEDICATED
  DOMAIN
  CDN
}

enum ServiceStatus {
  PENDING
  PROVISIONING
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
  FAILED
  ROLLBACK
  REINSTALLING
  SNAPSHOTTING
  DELETED
}

model Service {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          ServiceType
  status        ServiceStatus @default(PENDING)
  label         String
  planId        String?       @map("plan_id")
  monthlyPrice  Decimal       @map("monthly_price") @db.Decimal(12, 2)
  autoRenew     Boolean       @default(true) @map("auto_renew")
  renewsAt      DateTime?     @map("renews_at")
  expiresAt     DateTime?     @map("expires_at")
  suspendedAt   DateTime?     @map("suspended_at")
  metadata      Json?
  version       Int           @default(0)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  provisioningOperations ProvisioningOperation[]
  subscription      Subscription?
  vpsInstance       VpsInstance?
  dedicatedServer   DedicatedServer?
  domain            Domain?
  cdnZone           CdnZone?
  invoiceItems      InvoiceItem[]
  provisioningJobs  ProvisioningJob[]
  events            ServiceEvent[]

  @@index([userId, type])
  @@index([status])
  @@index([renewsAt])
  @@map("services")
}

model ProvisioningJob {
  id            String   @id @default(cuid())
  serviceId     String   @map("service_id")
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  type          String
  status        String   @default("queued")
  progress      Int      @default(0)
  steps         Json?
  currentStep   String?  @map("current_step")
  attempts      Int      @default(0)
  maxAttempts   Int      @default(3) @map("max_attempts")
  rollbackState Json?    @map("rollback_state")
  error         String?  @db.Text
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([serviceId])
  @@index([status])
  @@map("provisioning_jobs")
}

model ServiceEvent {
  id          String   @id @default(cuid())
  serviceId   String   @map("service_id")
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String?  @db.Text
  severity    String   @default("info")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([serviceId, createdAt])
  @@map("service_events")
}

// ─── VPS ────────────────────────────────────────────────────

model VpsInstance {
  id              String   @id @default(cuid())
  serviceId       String   @unique @map("service_id")
  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  nodeId          String?  @map("node_id")
  node            Node?    @relation(fields: [nodeId], references: [id])
  locationId      String   @map("location_id")
  location        Location @relation(fields: [locationId], references: [id])
  hostname        String
  primaryIp       String?  @map("primary_ip")
  ipv6            String?
  os              String   @default("debian-12")
  cpuCores        Int      @map("cpu_cores")
  ramMb           Int      @map("ram_mb")
  diskGb          Int      @map("disk_gb")
  bandwidthTb     Float    @default(1) @map("bandwidth_tb")
  bandwidthUsedGb Float    @default(0) @map("bandwidth_used_gb")
  cpuUsage        Float    @default(0) @map("cpu_usage")
  ramUsage        Float    @default(0) @map("ram_usage")
  diskUsage       Float    @default(0) @map("disk_usage")
  uptimeSeconds   BigInt   @default(0) @map("uptime_seconds")
  proxmoxVmid     Int?     @map("proxmox_vmid")
  rootPasswordEnc String?  @map("root_password_enc")
  rescueMode      Boolean  @default(false) @map("rescue_mode")
  cloudInit       Json?    @map("cloud_init")
  templateId      String?  @map("template_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  snapshots       VpsSnapshot[]

  @@index([nodeId])
  @@index([locationId])
  @@index([primaryIp])
  @@map("vps_instances")
}

// ─── Dedicated ──────────────────────────────────────────────

model DedicatedInventory {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  cpu         String
  ramGb       Int      @map("ram_gb")
  storage     String
  uplink      String
  locationId  String   @map("location_id")
  monthlyPrice Decimal @map("monthly_price") @db.Decimal(12, 2)
  stockTotal  Int      @default(0) @map("stock_total")
  stockAvail  Int      @default(0) @map("stock_avail")
  lowStockAt  Int      @default(2) @map("low_stock_at")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  servers DedicatedServer[]

  @@index([locationId])
  @@index([stockAvail])
  @@map("dedicated_inventory")
}

model DedicatedServer {
  id            String              @id @default(cuid())
  serviceId     String              @unique @map("service_id")
  service       Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  inventoryId   String?             @map("inventory_id")
  inventory     DedicatedInventory? @relation(fields: [inventoryId], references: [id])
  locationId    String              @map("location_id")
  location      Location            @relation(fields: [locationId], references: [id])
  hostname      String
  rack          String?
  uplink        String?
  primaryIp     String?             @map("primary_ip")
  assignedIps   Json?               @map("assigned_ips")
  ipmiUrl       String?             @map("ipmi_url")
  bandwidthTb   Float               @default(10) @map("bandwidth_tb")
  bandwidthUsedGb Float             @default(0) @map("bandwidth_used_gb")
  specs         Json?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([locationId])
  @@map("dedicated_servers")
}

// ─── Domains ──────────────────────────────────────────────────

enum DomainStatus {
  ACTIVE
  PENDING
  TRANSFER_IN
  TRANSFER_OUT
  EXPIRED
  REDEMPTION
}

model Domain {
  id           String       @id @default(cuid())
  serviceId    String       @unique @map("service_id")
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  domainName   String       @unique @map("domain_name")
  status       DomainStatus @default(PENDING)
  registrar    String       @default("dior")
  expiresAt    DateTime?    @map("expires_at")
  autoRenew    Boolean      @default(true) @map("auto_renew")
  nameservers  Json?
  dnsRecords   Json?        @map("dns_records")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@index([status])
  @@map("domains")
}

// ─── CDN ──────────────────────────────────────────────────────

model CdnZone {
  id            String   @id @default(cuid())
  serviceId     String   @unique @map("service_id")
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  zoneName      String   @unique @map("zone_name")
  status        String   @default("active")
  bandwidthGb   Float    @default(0) @map("bandwidth_gb")
  requests      BigInt   @default(0)
  cacheHitRatio Float    @default(0) @map("cache_hit_ratio")
  edgeRegions   CdnEdgeRegion[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("cdn_zones")
}

model CdnEdgeRegion {
  id        String  @id @default(cuid())
  zoneId    String  @map("zone_id")
  zone      CdnZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  locationId String @map("location_id")
  location  Location @relation(fields: [locationId], references: [id])
  requests  BigInt  @default(0)
  bandwidthGb Float @default(0) @map("bandwidth_gb")

  @@unique([zoneId, locationId])
  @@map("cdn_edge_regions")
}

// ─── Billing ──────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
  REFUNDED
}

model Invoice {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  number      String        @unique
  status      InvoiceStatus @default(PENDING)
  subtotal    Decimal       @db.Decimal(12, 2)
  tax         Decimal       @default(0) @db.Decimal(12, 2)
  total       Decimal       @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  currency    String        @default("USD")
  dueAt       DateTime?     @map("due_at")
  paidAt      DateTime?     @map("paid_at")
  notes       String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  items        InvoiceItem[]
  transactions Transaction[]

  @@index([userId, status])
  @@index([dueAt])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String   @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceId   String?  @map("service_id")
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)

  @@index([invoiceId])
  @@map("invoice_items")
}

enum TransactionType {
  CREDIT
  DEBIT
  PAYMENT
  REFUND
  REFERRAL
  ADJUSTMENT
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceId   String?         @map("invoice_id")
  invoice     Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  balanceAfter Decimal        @map("balance_after") @db.Decimal(12, 2)
  description String
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([invoiceId])
  @@map("transactions")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
  MANUAL_REVIEW
}

enum TopUpProvider {
  HELEKET
  CRYPTOBOT
  CRYSTALPAY
  MANUAL_TRANSFER
}

enum TopUpStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  EXPIRED
  REFUNDED
  MANUAL_REVIEW
}

enum PaymentMethod {
  BALANCE
  CRYPTO
  MANUAL
  TELEGRAM
  CARD
}

model Payment {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("USD")
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  externalId    String?       @map("external_id")
  webhookData   Json?         @map("webhook_data")
  retryCount    Int           @default(0) @map("retry_count")
  completedAt   DateTime?     @map("completed_at")
  failedAt      DateTime?     @map("failed_at")
  failureReason String?       @map("failure_reason") @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  events PaymentEvent[]

  @@index([userId, status])
  @@index([externalId])
  @@map("payments")
}

model PaymentEvent {
  id        String   @id @default(cuid())
  paymentId String   @map("payment_id")
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  event     String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([paymentId])
  @@map("payment_events")
}

// ─── Balance top-ups (unified payment center) ─────────────────

model TopUp {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(12, 2)
  fee             Decimal       @default(0) @db.Decimal(12, 2)
  netAmount       Decimal       @map("net_amount") @db.Decimal(12, 2)
  currency        String        @default("USD")
  provider        TopUpProvider
  status          TopUpStatus   @default(PENDING)
  idempotencyKey  String        @unique @map("idempotency_key")
  referenceCode   String        @unique @map("reference_code")
  externalId      String?       @map("external_id")
  paymentUrl      String?       @map("payment_url") @db.Text
  expiresAt       DateTime?     @map("expires_at")
  paidAt          DateTime?     @map("paid_at")
  failureReason   String?       @map("failure_reason") @db.Text
  metadata        Json?
  adminNotes      String?       @map("admin_notes") @db.Text
  reviewedById    String?       @map("reviewed_by_id")
  reviewedBy      User?         @relation("TopUpReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?     @map("reviewed_at")
  ledgerTxId      String?       @unique @map("ledger_tx_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  events TopUpEvent[]

  @@index([userId, status, createdAt])
  @@index([provider, externalId])
  @@index([status, createdAt])
  @@index([expiresAt])
  @@map("top_ups")
}

model TopUpEvent {
  id        String   @id @default(cuid())
  topUpId   String   @map("top_up_id")
  topUp     TopUp    @relation(fields: [topUpId], references: [id], onDelete: Cascade)
  event     String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([topUpId, createdAt])
  @@map("top_up_events")
}

model WebhookIdempotency {
  id          String   @id
  provider    String
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([provider, processedAt])
  @@map("webhook_idempotency")
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @map("discount_type")
  discountValue Decimal   @map("discount_value") @db.Decimal(12, 2)
  maxUses       Int?      @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  validFrom     DateTime? @map("valid_from")
  validUntil    DateTime? @map("valid_until")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("promo_codes")
}

// ─── Referrals ────────────────────────────────────────────────

model AffiliateTier {
  id              String   @id @default(cuid())
  name            String   @unique
  percent         Decimal  @db.Decimal(5, 2)
  minReferrals    Int      @default(0) @map("min_referrals")
  minEarnings     Decimal  @default(0) @map("min_earnings") @db.Decimal(12, 2)
  users           User[]
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("affiliate_tiers")
}

model ReferralEarning {
  id           String   @id @default(cuid())
  earnerId     String   @map("earner_id")
  earner       User     @relation("Earner", fields: [earnerId], references: [id], onDelete: Cascade)
  sourceUserId String   @map("source_user_id")
  sourceUser   User     @relation("Source", fields: [sourceUserId], references: [id], onDelete: Cascade)
  amount       Decimal  @db.Decimal(12, 2)
  invoiceId    String?  @map("invoice_id")
  description  String
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([earnerId, createdAt])
  @@index([sourceUserId])
  @@map("referral_earnings")
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

model PayoutRequest {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal      @db.Decimal(12, 2)
  method    String
  details   Json?
  status    PayoutStatus @default(PENDING)
  notes     String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("payout_requests")
}

// ─── Notifications ────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String    @db.Text
  link      String?
  read      Boolean   @default(false)
  readAt    DateTime? @map("read_at")
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")

  deliveries NotificationDelivery[]

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id              String  @id @default(cuid())
  userId          String  @unique @map("user_id")
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled    Boolean @default(true) @map("email_enabled")
  telegramEnabled Boolean @default(true) @map("telegram_enabled")
  inAppEnabled    Boolean @default(true) @map("in_app_enabled")
  quietHoursStart String? @map("quiet_hours_start")
  quietHoursEnd   String? @map("quiet_hours_end")
  categories      Json?

  @@map("notification_preferences")
}

model NotificationDelivery {
  id             String       @id @default(cuid())
  notificationId String       @map("notification_id")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel        String
  status         String       @default("pending")
  retryCount     Int          @default(0) @map("retry_count")
  sentAt         DateTime?    @map("sent_at")
  error          String?      @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([notificationId])
  @@index([status])
  @@map("notification_deliveries")
}

// ─── Support ──────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  AWAITING_CUSTOMER
  AWAITING_STAFF
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Ticket {
  id         String         @id @default(cuid())
  userId     String         @map("user_id")
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    String
  status     TicketStatus   @default(OPEN)
  priority   TicketPriority @default(NORMAL)
  assignedTo String?        @map("assigned_to")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  closedAt   DateTime?      @map("closed_at")

  messages TicketMessage[]

  @@index([userId, status])
  @@index([status, priority])
  @@map("tickets")
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String   @map("ticket_id")
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String   @map("author_id")
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body        String   @db.Text
  internal    Boolean  @default(false)
  attachments Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

model CannedResponse {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("canned_responses")
}

// ─── Abuse & Broadcasts ───────────────────────────────────────

model AbuseReport {
  id          String   @id @default(cuid())
  reporterEmail String? @map("reporter_email")
  targetType  String   @map("target_type")
  targetValue String   @map("target_value")
  description String   @db.Text
  status      String   @default("open")
  assignedTo  String?  @map("assigned_to")
  resolution  String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("abuse_reports")
}

model Broadcast {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  type      String   @default("info")
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("broadcasts")
}

// ─── Subscriptions (billing-owned) ───────────────────────────

model Subscription {
  id          String    @id @default(cuid())
  serviceId   String    @unique @map("service_id")
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  interval    String    @default("monthly")
  status      String    @default("active")
  nextRenewAt DateTime? @map("next_renew_at")
  graceUntil  DateTime? @map("grace_until")
  canceledAt  DateTime? @map("canceled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status, nextRenewAt])
  @@map("subscriptions")
}

// ─── Event store & system contracts ───────────────────────────

model DomainEvent {
  id             String   @id @default(cuid())
  eventType      String   @map("event_type")
  aggregateType  String   @map("aggregate_type")
  aggregateId    String   @map("aggregate_id")
  userId         String?  @map("user_id")
  payload        Json
  idempotencyKey String?  @unique @map("idempotency_key")
  correlationId  String?  @map("correlation_id")
  causationId    String?  @map("causation_id")
  streamPosition BigInt?  @map("stream_position")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([aggregateType, aggregateId, createdAt])
  @@index([eventType, createdAt])
  @@index([correlationId])
  @@map("domain_events")
}

model ProcessedIdempotencyKey {
  id        String   @id @default(cuid())
  scope     String
  key       String
  result    Json?
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@unique([scope, key])
  @@index([expiresAt])
  @@map("processed_idempotency_keys")
}

model ProvisioningOperation {
  id             String   @id @default(cuid())
  serviceId      String   @map("service_id")
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  operation      String
  idempotencyKey String   @unique @map("idempotency_key")
  status         String   @default("pending")
  proxmoxVmid    Int?     @map("proxmox_vmid")
  assignedIp     String?  @map("assigned_ip")
  error          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  @@index([serviceId, operation])
  @@map("provisioning_operations")
}

model UserRiskProfile {
  userId             String    @id @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  riskScore          Int       @default(0) @map("risk_score")
  abuseAction        String    @default("allow") @map("abuse_action")
  velocityHits       Int       @default(0) @map("velocity_hits")
  paymentFingerprint String?   @map("payment_fingerprint")
  frozenAt           DateTime? @map("frozen_at")
  metadata           Json?
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("user_risk_profiles")
}

model ManualReviewQueue {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason       String    @db.Text
  status       String    @default("open")
  riskScore    Int       @default(0) @map("risk_score")
  metadata     Json?
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  resolution   String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([userId])
  @@map("manual_review_queue")
}

model AsnReputation {
  asn      String   @id
  score    Int      @default(50)
  label    String?
  blocked  Boolean  @default(false)
  metadata Json?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("asn_reputation")
}

model PaymentFingerprint {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  fingerprintHash String   @map("fingerprint_hash")
  provider        String?
  walletHint      String?  @map("wallet_hint")
  hitCount        Int      @default(1) @map("hit_count")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([fingerprintHash])
  @@index([userId])
  @@map("payment_fingerprints")
}

model ReconciliationRun {
  id          String   @id @default(cuid())
  domain      String
  status      String   @default("running")
  findings    Json?
  fixesApplied Int     @default(0) @map("fixes_applied")
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@index([domain, startedAt])
  @@map("reconciliation_runs")
}

// ─── CQRS read projections (denormalized, event-driven updates only) ─

model ActivityReadModel {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  kind        String
  title       String
  subtitle    String?
  severity    String   @default("info")
  link        String?
  sourceEventId String? @unique @map("source_event_id")
  occurredAt  DateTime @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, occurredAt])
  @@map("activity_read_model")
}

model ServiceTimelineReadModel {
  id            String   @id @default(cuid())
  serviceId     String   @map("service_id")
  eventType     String   @map("event_type")
  title         String
  description   String?  @db.Text
  severity      String   @default("info")
  sourceEventId String?  @unique @map("source_event_id")
  occurredAt    DateTime @map("occurred_at")

  @@index([serviceId, occurredAt])
  @@map("service_timeline_read_model")
}

// ─── Rate limiting ────────────────────────────────────────────

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(1)
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("rate_limit_entries")
}

// ─── Settings: API keys & security ─────────────────────────────

model ApiKey {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String
  keyPrefix     String    @map("key_prefix")
  keyHash       String    @unique @map("key_hash")
  permissions   Json      @default("[]")
  rateLimitDay  Int       @default(1000) @map("rate_limit_day")
  requestsToday Int       @default(0) @map("requests_today")
  requestsReset DateTime  @default(now()) @map("requests_reset")
  lastUsedAt    DateTime? @map("last_used_at")
  lastUsedIp    String?   @map("last_used_ip")
  revokedAt     DateTime? @map("revoked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  auditLogs     ApiKeyAuditLog[]

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model ApiKeyAuditLog {
  id         String   @id @default(cuid())
  apiKeyId   String   @map("api_key_id")
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  method     String
  path       String
  ipAddress  String   @map("ip_address")
  statusCode Int      @map("status_code")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([apiKeyId, createdAt])
  @@map("api_key_audit_logs")
}

model TelegramLinkToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("telegram_link_tokens")
}

model TwoFactorRecoveryCode {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("two_factor_recovery_codes")
}
