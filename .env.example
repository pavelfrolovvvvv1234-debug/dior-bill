# Database
DATABASE_URL="mysql://dior:dior_secret@127.0.0.1:3306/dior_billing"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth — generate: openssl rand -hex 32
JWT_SECRET="change-me-jwt-secret"
SESSION_SECRET="change-me-session-secret"
ENCRYPTION_KEY="change-me-32-byte-base64-key"

# Telegram (Login Widget + bot — same bot token, shared MySQL users.telegram_id)
# 1) Create bot via @BotFather, set domain: /setdomain → your production host
# 2) TELEGRAM_BOT_USERNAME = name without @ (e.g. DiorHostBot)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""
# Admin alerts: chat id or group where bot is added (get via @userinfobot or getUpdates)
TELEGRAM_ADMIN_CHAT_ID=""
# Optional: comma-separated extra admin chats
# TELEGRAM_ADMIN_CHAT_IDS=""
TELEGRAM_WEBHOOK_SECRET=""

# App URLs
NEXT_PUBLIC_APP_URL="https://my.dior.host"
NEXT_PUBLIC_ADMIN_URL="https://my.dior.host"
NEXT_PUBLIC_API_URL="https://api.dior.host"
API_URL="https://api.dior.host"

# Proxmox (VPS provisioning)
VMM_EMAIL=
VMM_PASSWORD=
VMM_ENDPOINT_URL=
VM_PROVIDER=proxmox
PROXMOX_BASE_URL=
PROXMOX_NODE=pve01
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
PROXMOX_STORAGE=storage-lvm
PROXMOX_BRIDGE=vmbr0
PROXMOX_INSECURE_TLS=0
PROXMOX_TEMPLATE_MAP={}

# Amper — domain registrar API (token from Amper dashboard)
AMPER_API_BASE_URL=https://amper.lat/api/v1
AMPER_API_TOKEN=
AMPER_API_TIMEOUT_MS=8000

# Payment providers — balance top-up
TOPUP_EXPIRY_MINUTES=60

# Heleket (aliases: PAYMENT_HELEKET_* also supported)
HELEKET_MERCHANT_ID=
HELEKET_API_KEY=
HELEKET_API_URL=https://api.heleket.com/v1
HELEKET_WEBHOOK_SECRET=
# PAYMENT_HELEKET_MERCHANT=
# PAYMENT_HELEKET_API_KEY=
# PAYMENT_HELEKET_API_URL=https://api.heleket.com

# Crypto Pay (@CryptoBot wallet — NOT your Dior login bot)
CRYPTOBOT_API_TOKEN=
CRYPTOBOT_BOT_USERNAME=CryptoBot
NEXT_PUBLIC_CRYPTOBOT_BOT_USERNAME=CryptoBot
# PAYMENT_CRYPTOBOT_TOKEN=

# CrystalPay (aliases: PAYMENT_CRYSTALPAY_* also supported)
CRYSTALPAY_AUTH_LOGIN=
CRYSTALPAY_AUTH_SECRET=
CRYSTALPAY_CALLBACK_SECRET=
CRYSTALPAY_API_URL=https://api.crystalpay.io/v2
# PAYMENT_CRYSTALPAY_ID=
# PAYMENT_CRYSTALPAY_SECRET_ONE=
# PAYMENT_CRYSTALPAY_SECRET_TWO=

# Manual transfer support
NEXT_PUBLIC_MANUAL_SUPPORT_TELEGRAM="@your_support"