# Database
DATABASE_URL="mysql://dior:dior_secret@localhost:3306/dior_billing"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth — generate: openssl rand -hex 32
JWT_SECRET="change-me-generate-with-openssl-rand-hex-32"
SESSION_SECRET="change-me-generate-with-openssl-rand-hex-32"
ENCRYPTION_KEY="change-me-generate-with-openssl-rand-base64-24"

# Telegram (Login Widget + bot — same bot token, shared MySQL users.telegram_id)
# 1) Create bot via @BotFather, set domain: /setdomain → your production host
# 2) TELEGRAM_BOT_USERNAME = name without @ (e.g. DiorHostBot)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="your_bot_username"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"
# Admin alerts: chat id or group where bot is added (get via @userinfobot or getUpdates)
TELEGRAM_ADMIN_CHAT_ID=""
# Optional: comma-separated extra admin chats
# TELEGRAM_ADMIN_CHAT_IDS=""
TELEGRAM_WEBHOOK_SECRET=""

# App URLs
NEXT_PUBLIC_APP_URL="https://my.dior.host"
NEXT_PUBLIC_ADMIN_URL="https://my.dior.host"
NEXT_PUBLIC_API_URL="https://api.dior.host"
API_URL="https://api.dior.host"

# Proxmox (VPS provisioning)
VMM_EMAIL=test@example.com
VMM_PASSWORD=test
VMM_ENDPOINT_URL=https://test.example.com/
VM_PROVIDER=proxmox
PROXMOX_BASE_URL=https://your-pve-host:8006
PROXMOX_NODE=pve01
PROXMOX_TOKEN_ID=api-user@pam!token-name
PROXMOX_TOKEN_SECRET=your-proxmox-api-token-secret
PROXMOX_STORAGE=storage-lvm
PROXMOX_BRIDGE=vmbr0
# Set to 1 if PVE uses a self-signed certificate
PROXMOX_INSECURE_TLS=0
# Template VMIDs on the node (keys match OS slugs, see backend/src/proxmox/os-templates.ts)
PROXMOX_TEMPLATE_MAP={"ubuntu2204":102,"debian12":902}

# Amper — domain registrar API (token from Amper dashboard)
AMPER_API_BASE_URL=https://amper.lat/api/v1
AMPER_API_TOKEN=your-amper-api-token
AMPER_API_TIMEOUT_MS=8000

# Payment providers — balance top-up
TOPUP_EXPIRY_MINUTES=60

# Heleket
PAYMENT_HELEKET_MERCHANT=your-heleket-merchant-uuid
PAYMENT_HELEKET_API_KEY=your-heleket-api-key
PAYMENT_HELEKET_API_URL=https://api.heleket.com

# Telegram CryptoBot (@CryptoBot / Crypto Pay API)
PAYMENT_CRYPTOBOT_TOKEN=your-cryptobot-token

# CrystalPay
CRYSTALPAY_API_URL="https://api.crystalpay.io/v2"
PAYMENT_CRYSTALPAY_ID=your-crystalpay-login
PAYMENT_CRYSTALPAY_SECRET_ONE=your-crystalpay-secret-one
PAYMENT_CRYSTALPAY_SECRET_TWO=your-crystalpay-secret-two

# Manual transfer support
NEXT_PUBLIC_MANUAL_SUPPORT_TELEGRAM="@diorhost"
